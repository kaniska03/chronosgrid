# ---- Database (PostgreSQL is the source of truth in deployments) ----------
DATABASE_URL=postgresql+asyncpg://chronos:chronos@localhost:5432/chronosgrid

# ---- Redis (optional: cross-process WebSocket event fan-out) --------------
REDIS_URL=redis://localhost:6379/0

# ---- Auth ------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# ---- Scheduler tuning -------------------------------------------------------
LEASE_SECONDS=30
HEARTBEAT_SECONDS=10
WORKER_OFFLINE_AFTER_SECONDS=45
REAPER_INTERVAL_SECONDS=2.0
PRIORITY_AGING_INTERVAL_SECONDS=60
PRIORITY_AGING_MAX_BOOST=5

# ---- Limits -----------------------------------------------------------------
MAX_PAYLOAD_BYTES=65536
MAX_BATCH_SIZE=500
API_RATE_LIMIT_PER_MINUTE=240

# ---- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- AI failure assistant (optional; falls back to local analyzer) ---------
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5

# ---- Demo / seed -------------------------------------------------------------
SEED_DEMO_DATA=1

# ---- Worker ------------------------------------------------------------------
WORKER_NAME=worker-local
WORKER_CAPACITY=5
WORKER_TAGS=general
WORKER_CAPABILITIES=sleep,math,text_transform,http_check,report,flaky,always_fail
